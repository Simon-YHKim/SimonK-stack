# analytics-ad-wiring — env template
# 측정 ID·광고 단위 ID는 전부 env 주입. 소스 하드코딩 금지.
# 비워두면 fail-open 가드에 의해 해당 트래커/광고가 조용히 비활성된다 (앱은 정상 동작).
#
# 프리픽스 주의:
#   - 웹(Next/Vite) 클라이언트 노출 키는 빌드 도구 규칙을 따른다 (NEXT_PUBLIC_ / VITE_).
#   - Expo 클라이언트 노출 키는 EXPO_PUBLIC_ 프리픽스.
#   - 측정·광고 ID는 시크릿이 아니라 클라이언트 노출 식별자이므로 PUBLIC 프리픽스가 정상이다.

# ── 공통 ─────────────────────────────────────────────
# 운영/개발 분기. 개발·CI에서는 ANALYTICS_ENV=development → 테스트 광고 ID 강제.
ANALYTICS_ENV=development          # development | production

# ── 웹: 분석 ─────────────────────────────────────────
# GA4 Measurement ID 형식: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
# Microsoft Clarity Project ID (10자 영숫자)
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ── 웹: 광고 (AdSense) ───────────────────────────────
# AdSense Publisher ID 형식: ca-pub-0000000000000000
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=
# 광고 슬롯 ID (16자리 숫자). 슬롯별로 추가.
NEXT_PUBLIC_ADSENSE_SLOT_DEFAULT=

# ── RN / Expo: 분석 (Firebase Analytics) ─────────────
# Firebase 설정은 google-services.json / GoogleService-Info.plist 로 주입.
# Analytics on/off 토글만 env로 관리.
EXPO_PUBLIC_FIREBASE_ANALYTICS_ENABLED=true

# ── RN / Expo: 광고 (AdMob) ──────────────────────────
# AdMob App ID 형식: ca-app-pub-0000000000000000~0000000000  (~ 포함)
EXPO_PUBLIC_ADMOB_APP_ID_ANDROID=
EXPO_PUBLIC_ADMOB_APP_ID_IOS=
# 광고 단위 ID 형식: ca-app-pub-0000000000000000/0000000000  (/ 포함)
# 개발 빌드는 비워두면 SDK 테스트 ID로 자동 폴백 (rn-init.ts 참조).
EXPO_PUBLIC_ADMOB_BANNER_UNIT_ANDROID=
EXPO_PUBLIC_ADMOB_BANNER_UNIT_IOS=
