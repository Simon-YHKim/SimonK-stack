# ==============================================================================
# simon-stack .gitignore
# ==============================================================================

# Claude Code local state (per-user permissions cache, not shared)
.claude/settings.local.json

# Backups created by setup-repo.sh when overwriting existing hooks
.claude/hooks/*.bak
.claude/hooks/*.bak-*
**/*.bak
**/*.bak-*

# simon-stack bootstrap cache (never committed — per-user VM local)
.simon-stack-src/
~/.simon-stack-src/

# Graphify auto-generated output (regenerable via `graphify update .`)
graphify-out/

# simonk sprint cache (plan.md and log.md committed, transient cache ignored)
.simonk/cache/

# KeePassXC vault safety (실수 방지 가드 — vault 자체는 E:\Coding Infra root에 보관, repo 외부)
*.kdbx
*.kdb
*.kdbx.lock

# Install-time backups of ~/.claude
.claude.bak-*/

# Environment files (never commit secrets)
.env
.env.local
.env.*.local

# Node / Bun
node_modules/
bun.lockb
bun.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*

# OS artifacts
.DS_Store
Thumbs.db
Desktop.ini
._*

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# Logs
*.log
/tmp/simon-stack-*.log

# Test / coverage
coverage/
.nyc_output/

# Temporary
*.tmp
*.temp

# Python
__pycache__/
*.pyc
*.pyo

# Context Guardian (session-local state)
SESSION_RECOVERY.md
context_limit_log.json
CLAUDE.md.bak-*

# Harness / Wiki (user-local overrides)
# state.json + plan.md + wiki/ are committed. Local overrides are ignored.
.harness/*.local.*
.harness/**/*.local.*
